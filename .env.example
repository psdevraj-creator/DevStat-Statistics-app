# DevStat Environment Configuration
# Copy this file to .env and fill in your values.
# NOTE: The portable release does NOT require any API keys.
# This file is only needed if running from source with AI features enabled.

# DeepSeek API configuration (only needed for AI Assistant feature)
# DEEPSEEK_API_KEY=your-api-key-here
# DEEPSEEK_MODEL=deepseek/deepseek-v4-pro
